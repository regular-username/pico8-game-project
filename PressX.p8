--interactable class

function new_interactable(name,x,y,question,yes_text,no_text,yes_score,no_score)

return{
name=name,
x=x,
y=y,
used=false, --can't use after first interaction
question=question,  --text for question
yes_text=yes_text,  --text for yes/no
no_text=no_text,
yes_score=yes_score,
no_score=no_score,


draw_ui=function(self)
  rectfill(20,108,108,120,0)
  print("press ❎ to interact",30,110,7)
  end
  }
  
end

--create objects
function make_interactables()
  interactables={}
  
  -- plant
  add(interactables,new_interactable(
    "plant",7,6,
    "water plant? 1x=yes,2x=no",
    "the plant is thriving!",
    "the plant dried up...",
    1,-1
  ))

  -- computer
  add(interactables,new_interactable(
    "computer",22,13,
    "commit fraud? 1x=no,2x=yes",
    "you stayed honest.",
    "consequences will follow.",
    1,-1
  ))

  -- bed
  add(interactables,new_interactable(
    "bed",4,6,
    "rest or scroll? 1x=rest,2x=phone",
    "you feel refreshed.",
    "you wasted hours.",
    1,-1
  ))

  -- bookshelf
  add(interactables,new_interactable(
    "bookshelf",2,3,
    "read? 1x=read,2x=ignore",
    "you learned something new.",
    "you chose ignorance.",
    1,-1
  ))

  -- window
  add(interactables,new_interactable(
    "window",5,2,
    "open window? 1x=yes,2x=no",
    "fresh air clears your mind.",
    "the room feels suffocating.",
    1,-1
  ))

  -- painting
  add(interactables,new_interactable(
    "painting",14,2,
    "vandalise? 1x=admire,2x=ruin",
    "you appreciate beauty.",
    "you ruined something meaningful.",
    1,-1
  ))

  -- trash can
  add(interactables,new_interactable(
    "trash",20,12,
    "clean up? 1x=yes,2x=no",
    "you respect your space.",
    "you live in your own mess.",
    1,-1
  ))

  -- sink
  add(interactables,new_interactable(
    "sink",27,3,
    "brush teeth? 1x=yes,2x=no",
    "you stay clean.",
    "you get sick.",
    1,-1
  ))
end

function all_interactions_done()

 for obj in all(interactables) do
   if not obj.used then
      return false
   end
 end

 return true
end

--interaction system

function get_near_interactable()

  for obj in all(interactables) do
  if abs(p.x/8-obj.x)<1
  and abs(p.y/8-obj.y)<1 then
   return obj
  end
end

return nil
end

function handle_interaction()

  if press_timer>0
  then press_timer-=1 end

  -- idle
  if interaction_state=="idle" then   --start questiom if object not used
    local obj=get_near_interactable()
    if obj and not obj.used and btnp(❎) then
      interaction_state="question"  --wait first press etc
      current_obj=obj
      message=obj.question
      message_timer=999
      press_count=0
      question_timer=0
      voice_message=nil
    end

  -- question
  elseif interaction_state=="question" then

    if press_count==0 then
       -- wait for first button push
       if btnp(❎) then
          press_count+=1
          question_timer=25
          
       end
       else
         if btnp(❎) then
         press_count+=1
         question_timer=0
       end

   question_timer-=1
       if question_timer<=0 then
           
local result_msg=""


if press_count==1 then
   result_msg=current_obj.yes_text
   moral_score+=current_obj.yes_score
   sfx(3)
else
   result_msg=current_obj.no_text
   moral_score+=current_obj.no_score
   sfx(2)
end


message=result_msg
message_timer=90


-- different message
voice_message=nil
if (press_count==1 
and current_obj.yes_score <= 0)
or (press_count>1 
and current_obj.no_score <= 0) then

if moral_score <= -3 then
   voice_message="why are you doing this?"
end

if moral_score <= -4 then
   voice_message="this way i'll stop you."
end

if moral_score <= -5 then
   voice_message="please...stop..."
end

if moral_score <= -6 then
   voice_message="you are hurting me."
end
end
              

current_obj.used=true
if all_interactions_done() then

if moral_score <= -6 then
      game_state="bad_ending"
   else
      game_state="good_ending"
   end

end
message_timer=90
interaction_state="result"
press_count=0
question_timer=0
end
end

  -- result
  elseif interaction_state=="result" then
    if message_timer<=0 then
      interaction_state="idle"
      current_obj=nil
    end
  end

  if message_timer>0 then message_timer-=1 end
end

--ui

function draw_ui()
  if interaction_state=="idle" then
    local obj=get_near_interactable()
    if obj and not obj.used then
      obj:draw_ui()
    end
  end
end

function draw_message()

  -- message 
   if voice_message and moral_score <= -3 then

    local w = #voice_message*4
    local x = (128-w)/2

    rectfill(x-2,10,x+w+2,22,0)
    print(voice_message,x,14,8)

  
  elseif message_timer>0 then

    local w = #message*4
    local x = (128-w)/2

    rectfill(x-2,100,x+w+2,120,0)
    print(message,x,108,7)

  end
end
