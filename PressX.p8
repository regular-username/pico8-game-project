--map code

function map_setup()
   wall=0
   interactable=1
   
   anim1=3    --tile types
   anim2=4
   lose=6
   win=7
   
   --map size
   map_w=32
   map_h=16
end

function draw_map()

   --map size in pixels
   local map_pixel_w=map_w*8
   local map_pixel_h=map_h*8

   --camera follow
   local cam_x = p.x-64
   local cam_y = p.y-64
   
   --stop camera leaving map
   cam_x=mid(0,cam_x,map_pixel_w-128)
   cam_y=mid(0,cam_y,map_pixel_h-128)
   
   camera(cam_x, cam_y)
   
   if moral_score <=-5 then
    camera(cam_x+rnd(2)-1, cam_y+rnd(2)-1)
   end
   
   map(0,0,0,0,map_w,map_h)
   
end

function is_tile(tile_type, x, y)
   local tile=mget(x,y)
   return fget(tile,tile_type)
end

function can_move(tx, ty)              --checks if you can walk on the tile  
   return not is_tile(wall, tx, ty)
end

-- verify pixel colliders
function can_move_pixel(x, y)

--hitbox only on feet
   local left=x+2
   local right=x+5    --player edges
   local feet=y+7
   
   
   
--verify only bottom
   if not can_move(flr(left/8), flr(feet/8))
    then return false
    end
    
   if not can_move(flr(right/8), flr(feet/8))
    then return false
    end
   

   return true
end

-->8
--player code

function make_player()
   p={}
   p.x=3*8         -- pixels
   p.y=5*8
   p.sprite=1

   p.moving=false
   p.frame=0
   p.speed=1   -- pixels per frame
   p.facing=1
   
end

function draw_player()
   if p.facing==1 then
    spr(p.sprite,p.x,p.y)
   else
    spr(p.sprite,p.x,p.y,1,1,true,false) --flip horizontal
   
   end
end

function move_player()
   

   -- lock movement during interaction
   if interaction_state~="idle" then
      return
   end
   p.moving=false  --reset each frame

   local invert = (moral_score <= -4)

   -- left / right
   if invert then

      -- left becomes right
      if btn(⬅️) then 
         if can_move_pixel(p.x+p.speed, p.y) then
            p.x+=p.speed
            p.moving=true
            p.facing=1
         else
            sfx(0)
         end
      end

      -- right becomes left
      if btn(➡️) then 
         if can_move_pixel(p.x-p.speed, p.y) then
            p.x-=p.speed
            p.moving=true
            p.facing=-1
         else
            sfx(0)
         end
      end
      
      -- up becomes down
      if btn(⬆️) then 
         if can_move_pixel(p.x, p.y+p.speed) then
            p.y+=p.speed
            p.moving=true
         else
            sfx(0)
         end
      end

      -- down becomes up
      if btn(⬇️) then 
         if can_move_pixel(p.x, p.y-p.speed) then
            p.y-=p.speed
            p.moving=true
         else
            sfx(0)
         end
      end

   else

      --  normal controls
      if btn(⬅️) then 
         if can_move_pixel(p.x-p.speed, p.y) then
            p.x-=p.speed
            p.moving=true
            p.facing=-1
         else
            sfx(0)
         end
      end

      if btn(➡️) then 
         if can_move_pixel(p.x+p.speed, p.y) then
            p.x+=p.speed
            p.moving=true
            p.facing=1
         else
            sfx(0)
         end
      end

      if btn(⬆️) then 
         if can_move_pixel(p.x, p.y-p.speed) then
            p.y-=p.speed
            p.moving=true
         else
            sfx(0)
         end
      end

      if btn(⬇️) then 
         if can_move_pixel(p.x, p.y+p.speed) then
            p.y+=p.speed
            p.moving=true
         else
            sfx(0)
         end
      end

   end
end

-- walking/idle
function animate_player()
   p.frame = (p.frame + 1) % 20  -- counter animation

   if p.moving then
      -- walking animation 4 cadre
      if p.frame < 5 then
         p.sprite=3             --changes sprite according to time
      elseif p.frame < 10 then
         p.sprite=4
      elseif p.frame < 15 then
         p.sprite=5
      else
         p.sprite=6
      end
   else
      -- idle animation 2 cadre
      if p.frame < 10 then
         p.sprite=1
      else
         p.sprite=2
      end
   end
end


