pico-8 cartridge // http://www.pico-8.com
version 43
__lua__
--game loop 

function _init()
   map_setup()
   make_player()
end

function _update()
   move_player()
   animate_player() 
end

function _draw()
   cls()
   draw_map()
   draw_player()
end



-->8
--map code

function map_setup()
   wall=0
   door=2
   anim1=3
   anim2=4
   lose=6
   win=7
end

function draw_map()

   -- camera follows player
   camera(p.x-64, p.y-64)
   map(0,0,0,0,128,64)
end

function is_tile(tile_type, x, y)
   tile=mget(x,y)
   has_flag=fget(tile,tile_type)
   return has_flag
end

function can_move(tx, ty)
   return not is_tile(wall, tx, ty)
end

-- verify colliders
function can_move_pixel(x, y)
   local left=x
   local right=x+7
   local top=y
   local bottom=y+7

   if not can_move(flr(left/8), flr(top/8))
    then return false
    end
   if not can_move(flr(right/8), flr(top/8))
    then return false
    end
   if not can_move(flr(left/8), flr(bottom/8))
    then return false
    end
   if not can_move(flr(right/8), flr(bottom/8))
    then return false 
    end

   return true
end

-->8
--player code

function make_player()
   p={}
   p.x=3*8         -- pixeli
   p.y=5*8
   p.sprite=1

   p.moving=false
   p.frame=0
   p.speed=1       -- pixeli per frame
end

function draw_player()
   spr(p.sprite, p.x, p.y)
end

function move_player()
   p.moving=false

   if btn(⬅️) then 
      if can_move_pixel(p.x-p.speed, p.y) then
         p.x-=p.speed
         p.moving=true
      else
         sfx(0)
      end
   end
   if btn(➡️) then 
      if can_move_pixel(p.x+p.speed, p.y) then
         p.x+=p.speed
         p.moving=true
      else
         sfx(0)
      end
   end
   if btn(⬆️) then 
      if can_move_pixel(p.x, p.y-p.speed) then
         p.y-=p.speed
         p.moving=true
      else
         sfx(0)
      end
   end
   if btn(⬇️) then 
      if can_move_pixel(p.x, p.y+p.speed) then
         p.y+=p.speed
         p.moving=true
      else
         sfx(0)
      end
   end
end

-- animaっいie walking/idle
function animate_player()
   p.frame = (p.frame + 1) % 20  -- counter animaっいie

   if p.moving then
      -- walking animation 4 cadre
      if p.frame < 5 then
         p.sprite=3
      elseif p.frame < 10 then
         p.sprite=4
      elseif p.frame < 15 then
         p.sprite=5
      else
         p.sprite=6
      end
   else
      -- idle animation 2 cadre
      if p.frame < 10 then
         p.sprite=1
      else
         p.sprite=2
      end
   end
end
