pico-8 cartridge // http://www.pico-8.com
version 43
__lua__
--game loop 

function _init()
   map_setup()
   make_player()
  
end

function _update()
   move_player()
   animate_player() 
end

function _draw()
   cls()
   draw_map()
   draw_player()
end



-->8
--map code

function map_setup()
   wall=0
   anim1=3    --tile types
   anim2=4
   lose=6
   win=7
   
   --map size
   map_w=32
   map_h=16
end

function draw_map()

   --map size in pixels
   local map_pixel_w=map_w*8
   local map_pixel_h=map_h*8

   --camera follow
   local cam_x = p.x-64
   local cam_y = p.y-64
   
   --stop camera leaving map
   cam_x=mid(0,cam_x,map_pixel_w-128)
   cam_y=mid(0,cam_y,map_pixel_h-128)
   
   camera(cam_x, cam_y)
   
   map(0,0,0,0,map_w,map_h)
   
end

function is_tile(tile_type, x, y)
   tile=mget(x,y)
   has_flag=fget(tile,tile_type)   --checks the flag
   return has_flag
end

function can_move(tx, ty)              --checks if you can walk on the tile  
   return not is_tile(wall, tx, ty)
end

-- verify pixel colliders
function can_move_pixel(x, y)
   local left=x
   local right=x+7    --player edges
   local top=y
   local bottom=y+7
   
   
--verify each corner
   if not can_move(flr(left/8), flr(top/8))
    then return false
    end
   if not can_move(flr(right/8), flr(top/8))
    then return false
    end
   if not can_move(flr(left/8), flr(bottom/8))
    then return false
    end
   if not can_move(flr(right/8), flr(bottom/8))
    then return false 
    end

   return true
end

-->8
--player code

function make_player()
   p={}
   p.x=3*8         -- pixeli
   p.y=5*8
   p.sprite=1

   p.moving=false
   p.frame=0
   p.speed=1   -- pixeli per frame
   p.facing=1
   
end

function draw_player()
   if p.facing==1 then
    spr(p.sprite,p.x,p.y)
   else
    spr(p.sprite,p.x,p.y,1,1,true,false) --flip horizontal
   
   end
end

function move_player()
   

   p.moving=false  --reset each frame

   if btn(⬅️) then 
      if can_move_pixel(p.x-p.speed, p.y) then
         p.x-=p.speed
         p.moving=true
         p.facing=-1    --player looks left
      else
         sfx(0)
      end
   end
   if btn(➡️) then 
      if can_move_pixel(p.x+p.speed, p.y) then
         p.x+=p.speed
         p.moving=true
         p.facing=1    --player looks right
      else
         sfx(0)
      end
   end
   if btn(⬆️) then 
      if can_move_pixel(p.x, p.y-p.speed) then
         p.y-=p.speed
         p.moving=true
      else
         sfx(0)
      end
   end
   if btn(⬇️) then 
      if can_move_pixel(p.x, p.y+p.speed) then
         p.y+=p.speed
         p.moving=true
      else
         sfx(0)
      end
   end
end

-- walking/idle
function animate_player()
   p.frame = (p.frame + 1) % 20  -- counter animation

   if p.moving then
      -- walking animation 4 cadre
      if p.frame < 5 then
         p.sprite=3             --changes sprite according to time
      elseif p.frame < 10 then
         p.sprite=4
      elseif p.frame < 15 then
         p.sprite=5
      else
         p.sprite=6
      end
   else
      -- idle animation 2 cadre
      if p.frame < 10 then
         p.sprite=1
      else
         p.sprite=2
      end
   end
end
